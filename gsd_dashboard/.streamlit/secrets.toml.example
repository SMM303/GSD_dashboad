# Copy this file to .streamlit/secrets.toml and fill in values.
# secrets.toml is gitignored — never commit real credentials.

# --- Demo mode (set to true to run without Supabase/Google) ---
DEMO_MODE = true
SESSION_TIMEOUT_MINUTES = 30

# --- Supabase (required when DEMO_MODE = false) ---
SUPABASE_URL = "https://project-ref.supabase.co"
SUPABASE_ANON_KEY = "anon-key"
SUPABASE_SERVICE_ROLE_KEY = "service-role-key"   # ETL sidecar only

# --- Google Sheets (required when DEMO_MODE = false) ---
GOOGLE_SPREADSHEET_ID = "spreadsheet-id"

[gcp_service_account]
type = "service_account"
project_id = "project-id"
private_key_id = "key-id"
private_key = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email = "dashboard-etl@project.iam.gserviceaccount.com"
client_id = "numeric-client-id"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"

# --- Production authentication ---
# Run scripts/generate_hashes.py to produce bcrypt hashes, then paste below.
# In DEMO_MODE the app uses plain-text passwords defined in auth/setup.py.
[auth_credentials.credentials.usernames.bootstrap_admin]
name = "Bootstrap Admin"
password = "$2b$12$replace_with_generated_bcrypt_hash"
role = "admin"
